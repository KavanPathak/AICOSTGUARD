# Database Setup
DATABASE_URL="postgresql://postgres:password@localhost:5432/aicostguard?schema=public"

# App config
PORT=4000
NODE_ENV=development
LOG_LEVEL=info

# Security
JWT_SECRET="generate-a-secure-random-secret-key-for-jwt"
JWT_EXPIRES_IN="7d"

# OpenAI Proxy defaults
# Optional: Set server-wide key or let client supply it via X-OpenAI-API-Key header
OPENAI_API_KEY="sk-proj-your-openai-api-key"
